# Prefer beamng-mcp.toml. Environment variables override TOML values.
BEAMNG_MCP_CONFIG=beamng-mcp.toml
BEAMNG_MCP_BEAMNG_HOME=C:\\Games\\BeamNG.drive
BEAMNG_MCP_BEAMNG_BINARY=Bin64\\BeamNG.drive.x64.exe
BEAMNG_MCP_BEAMNG_USER=C:\\Users\\you\\AppData\\Local\\BeamNG\\BeamNG.drive\\current
BEAMNG_MCP_BLENDER_EXECUTABLE=C:\\Users\\you\\Applications\\Blender\\4.5.4\\blender.exe
BEAMNG_MCP_LUA_URL=ws://127.0.0.1:8765
BEAMNG_MCP_SAFETY_LEASE_SECONDS=1.0
BEAMNG_MCP_SAFETY_STARTUP_GRACE_SECONDS=5.0
BEAMNG_MCP_ALLOW_MOD_INSTALL=false
BEAMNG_MCP_ALLOW_EXISTING_MAP_OBJECT_EDITS=false
BEAMNG_MCP_ALLOW_PERSISTENT_MAP_EDITS=false
# Generated by `beamng-mcp install-lua`; never commit the real value.
BEAMNG_MCP_LUA_TOKEN=
